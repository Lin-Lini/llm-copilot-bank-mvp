# Example environment configuration for the LLM copilot backend.
#
# Copy this file to `.env` and adjust the values as necessary.  All
# variables correspond to fields defined in ``libs/common/config.Settings``.

# Database and Redis configuration
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/copilot
REDIS_URL=redis://redis:6379/0

CHAT_BUS_BACKEND=redis
CHAT_BUS_PREFIX=copilot:chat

# MinIO/S3 configuration for document storage
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=copilot-docs
MINIO_SECURE=false

# Kafka configuration
KAFKA_BOOTSTRAP=kafka:9092
KAFKA_ENABLED=true

# MCP Tools service URL
MCP_TOOLS_URL=http://mcp-tools:8090

WORKER_CONCURRENCY=4
WORKER_QUEUE_BLOCK_TIMEOUT_SEC=1
WORKER_RECLAIM_INTERVAL_SEC=5

# --- LLM configuration ---
#
# Endpoints for external LLM gateway/adapters.  Leave these blank to use
# the built-in deterministic stub during local development.  Provide full
# URLs when connecting to a real LLM service.
LLM_ANALYZE_URL=
LLM_DRAFT_URL=
LLM_EXPLAIN_URL=
LLM_GHOST_STREAM_URL=

# Provider mode:
# - stub (default)
# - contracts_http (use the URLs above and return AnalyzeV1/DraftV1/ExplainV1 JSON)
# - openai_compat (talk directly to /v1/chat/completions; set BASE_URL + models)
LLM_PROVIDER=stub
LLM_BASE_URL=
LLM_ANALYZE_MODEL=
LLM_DRAFT_MODEL=
LLM_EXPLAIN_MODEL=
LLM_GHOST_MODEL=
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=800

# Embeddings / RAG
EMBED_PROVIDER=stub
EMBED_BASE_URL=
EMBED_MODEL=

# API key or bearer token used to authorize requests to the LLM service
LLM_API_KEY=
# Built-in seed corpus directory used by /api/v1/docs/bootstrap-seed
RAG_SEED_DIR=docs/rag_corpus

INTERNAL_AUTH_TOKEN=dev-internal-token
INTERNAL_AUTH_SIGNING_KEY=replace-with-long-random-secret
INTERNAL_AUTH_TTL_SEC=60
INTERNAL_AUTH_AUDIENCE=internal
INTERNAL_AUTH_ALLOWED_ISSUERS=backend,worker,mcp-tools
INTERNAL_AUTH_CLOCK_SKEW_SEC=10
INTERNAL_AUTH_REQUIRE_REQUEST_ID=true
INTERNAL_AUTH_ALLOW_LEGACY_TOKEN=false
INTERNAL_AUTH_REQUIRE_SIGNED_FOR_SERVICE=true
INTERNAL_AUTH_REQUIRE_SIGNED_FOR_OPERATOR=true
INTERNAL_AUTH_REQUIRE_SIGNED_FOR_ALL=false